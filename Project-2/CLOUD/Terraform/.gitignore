# Terraform .gitignore

# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files except environment-specific ones
*.tfvars
*.tfvars.json
!terraform.tfvars.example
!environments/**/*.tfvars

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
*.plan

# Ignore lock files (optional - recommended to commit)
# .terraform.lock.hcl

# IDE and editor files
.idea/
*.swp
*.swo
*~
.vscode/
*.sublime-project
*.sublime-workspace
.DS_Store

# OS files
Thumbs.db
.terraform.lock.hcl

# Temporary files
*.tmp
*.temp
*.bak

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log

# Terraform apply output
tfapply.log
tfplan.log

# ArgoCD related
.argocd/
kube/

# Backup files
*.backup
*.bkp

# Generated files
kubeconfig
kubeconfig.*
